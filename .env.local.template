# .env.local — copy this file and fill in your values
# NEVER commit this file to version control

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only used server-side, never exposed to browser
# Found in: Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Setup Checklist ───────────────────────────────────────────────────────────
#
# 1. Run supabase_setup.sql in Supabase SQL Editor
#
# 2. Install dependencies:
#    npm install
#
# 3. Create your admin user:
#    Supabase Dashboard → Authentication → Users → Invite user
#    (or use the Supabase CLI)
#
# 4. Run the dev server:
#    npm run dev
#
# 5. Visit:
#    http://localhost:3000           → Public gallery
#    http://localhost:3000/admin/login → Admin login
